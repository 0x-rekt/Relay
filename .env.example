# Database Connection (Neon / PostgreSQL)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# BetterAuth Configuration
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:3000

# BetterAuth OAuth Login Providers (for User Authentication)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Encryption Key (32-byte string for AES-256-GCM encryption of integration tokens)
ENCRYPTION_KEY=your_32_character_encryption_key_here

# -----------------------------------------------------------------------------
# Workspace Integrations (OAuth Credentials for Developer Tools)
# -----------------------------------------------------------------------------

# GitHub Integration
INTEGRATION_GITHUB_CLIENT_ID=your_github_integration_client_id
INTEGRATION_GITHUB_CLIENT_SECRET=your_github_integration_client_secret

# Slack Integration
INTEGRATION_SLACK_CLIENT_ID=your_slack_integration_client_id
INTEGRATION_SLACK_CLIENT_SECRET=your_slack_integration_client_secret

# Linear Integration
INTEGRATION_LINEAR_CLIENT_ID=your_linear_integration_client_id
INTEGRATION_LINEAR_CLIENT_SECRET=your_linear_integration_client_secret

# Jira Integration
INTEGRATION_JIRA_CLIENT_ID=your_jira_integration_client_id
INTEGRATION_JIRA_CLIENT_SECRET=your_jira_integration_client_secret

# Sentry Integration
INTEGRATION_SENTRY_CLIENT_ID=your_sentry_integration_client_id
INTEGRATION_SENTRY_CLIENT_SECRET=your_sentry_integration_client_secret

# PagerDuty Integration
INTEGRATION_PAGERDUTY_CLIENT_ID=your_pagerduty_integration_client_id
INTEGRATION_PAGERDUTY_CLIENT_SECRET=your_pagerduty_integration_client_secret

# Vercel Integration
INTEGRATION_VERCEL_CLIENT_ID=your_vercel_integration_client_id
INTEGRATION_VERCEL_CLIENT_SECRET=your_vercel_integration_client_secret
